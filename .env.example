# New API 连接配置（必填）
NEWAPI_BASE=http://127.0.0.1:3000
NEWAPI_USERNAME=admin
NEWAPI_PASSWORD=your-password

# 对外访问地址（用于接入工具页面展示）
PUBLIC_API_URL=http://your-server-ip:3000

# 探测配置（可选）
POLL_INTERVAL=1800
PROBE_TIMEOUT=15
PROBE_WORKERS=6
PROBE_MAX_TOKENS=3
MODEL_HISTORY_LIMIT=30
PROBE_TOKEN_NAME=
PROBE_PROMPT=hi

# 服务端口（可选）
LISTEN_PORT=8890
HTTPS_PORT=8891
CERT_FILE=cert.pem
KEY_FILE=key.pem
